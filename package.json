{
  "name": "@eliottgdl/git-wrapped",
  "version": "0.1.3",
  "description": "Spotify Wrapped, but it roasts your git repo.",
  "type": "module",
  "bin": {
    "git-wrapped": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EliottGand/git-wrapped.git"
  },
  "scripts": {
    "dev": "bun src/cli/index.tsx",
    "build": "tsc -p tsconfig.json",
    "start": "bun dist/cli/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "git",
    "cli",
    "stats",
    "wrapped",
    "roast"
  ],
  "license": "MIT",
  "dependencies": {
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
