#!/usr/bin/env bash
#
# deploy — commit everything, bump the version, push to GitHub, publish to npm.
#
# Usage:
#   ./deploy              # patch bump (0.1.3 -> 0.1.4)
#   ./deploy minor        # minor bump (0.1.3 -> 0.2.0)
#   ./deploy major        # major bump (0.1.3 -> 1.0.0)
#
set -euo pipefail

cd "$(dirname "$0")"

info()  { printf '\033[1;34m›\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m!\033[0m %s\n' "$*"; }
error() { printf '\033[1;31m✗\033[0m %s\n' "$*" >&2; }

bump="${1:-patch}"
case "$bump" in
  patch|minor|major) ;;
  *) error "Unknown bump type '$bump' (use patch, minor, or major)."; exit 1 ;;
esac

# Build a conventional-commit message from the changed files.
generate_message() {
  local files type scope
  files="$(git status --porcelain | awk '{print $2}')"
  [ -z "$files" ] && { echo "chore: update project"; return; }

  # Pick a type: docs-only -> docs, otherwise feat.
  if echo "$files" | grep -qivE '\.(md|txt)$|^docs/'; then
    type="feat"
  else
    type="docs"
  fi

  # Scope = the most common top-level path segment (src, cli, …).
  scope="$(echo "$files" | sed 's#/.*##' | sort | uniq -c | sort -rn | head -1 | awk '{print $2}')"
  # Drop the extension if the "scope" is actually a root-level file.
  scope="${scope%.*}"

  local count
  count="$(echo "$files" | grep -c .)"
  echo "$type($scope): update $count file(s)"
}

# 1. Commit everything -------------------------------------------------------
if [ -n "$(git status --porcelain)" ]; then
  msg="$(generate_message)"
  info "Committing all changes: \"$msg\""
  git add -A
  git commit -m "$msg"
else
  info "Nothing to commit, working tree clean."
fi

# 2. Bump the version (creates a commit + tag) -------------------------------
info "Bumping version ($bump)…"
new_version="$(npm version "$bump" -m "chore(release): v%s")"
info "New version: $new_version"

# 3. Push to GitHub (with tags) ----------------------------------------------
branch="$(git rev-parse --abbrev-ref HEAD)"
info "Pushing '$branch' and tags to origin…"
git push origin "$branch" --follow-tags

# 4. Make sure we're logged in to npm ----------------------------------------
if ! npm whoami >/dev/null 2>&1; then
  warn "You are not logged in to npm."
  info "Launching 'npm login'…"
  npm login
  npm whoami >/dev/null 2>&1 || { error "npm login failed, aborting."; exit 1; }
fi
info "Logged in to npm as $(npm whoami)."

# 5. Build -------------------------------------------------------------------
info "Building…"
npm run build

# 6. Publish (with one-time password) ----------------------------------------
read -r -p "npm publish OTP (leave blank if you don't use 2FA): " otp
if [ -n "$otp" ]; then
  npm publish --otp "$otp"
else
  npm publish
fi

info "Done. Published $(node -p "require('./package.json').name")@$(node -p "require('./package.json').version")."
