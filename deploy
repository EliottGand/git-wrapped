#!/usr/bin/env bash
#
# deploy — commit everything, push to GitHub, then publish to npm.
#
# Usage:
#   ./deploy                 # prompts for a commit message
#   ./deploy "my message"    # use the given commit message
#
set -euo pipefail

cd "$(dirname "$0")"

info()  { printf '\033[1;34m›\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m!\033[0m %s\n' "$*"; }
error() { printf '\033[1;31m✗\033[0m %s\n' "$*" >&2; }

# 1. Commit everything -------------------------------------------------------
if [ -n "$(git status --porcelain)" ]; then
  msg="${1:-}"
  if [ -z "$msg" ]; then
    read -r -p "Commit message: " msg
  fi
  [ -z "$msg" ] && { error "Empty commit message, aborting."; exit 1; }

  info "Committing all changes…"
  git add -A
  git commit -m "$msg"
else
  info "Nothing to commit, working tree clean."
fi

# 2. Push to GitHub ----------------------------------------------------------
branch="$(git rev-parse --abbrev-ref HEAD)"
info "Pushing '$branch' to origin…"
git push origin "$branch"

# 3. Make sure we're logged in to npm ----------------------------------------
if ! npm whoami >/dev/null 2>&1; then
  warn "You are not logged in to npm."
  info "Launching 'npm login'…"
  npm login
  # Bail out if login still didn't work.
  npm whoami >/dev/null 2>&1 || { error "npm login failed, aborting."; exit 1; }
fi
info "Logged in to npm as $(npm whoami)."

# 4. Build -------------------------------------------------------------------
info "Building…"
npm run build

# 5. Publish (with one-time password) ----------------------------------------
read -r -p "npm publish OTP (leave blank if you don't use 2FA): " otp
if [ -n "$otp" ]; then
  npm publish --otp "$otp"
else
  npm publish
fi

info "Done. Published $(node -p "require('./package.json').name")@$(node -p "require('./package.json').version")."
